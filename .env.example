# Spotiflac-Lidarr Proxy configuration
# Copy this to .env and adjust for your setup

# Required: API key for Lidarr authentication
SPF_API_KEY=change-me-to-a-random-string

# HTTP listen port
SPF_PORT=8484

# Where completed FLAC downloads land (shared with Lidarr)
SPF_OUTPUT_DIR=/downloads

# Path to SpotiFLAC CLI binary
SPF_SPOTIFLAC_CLI_PATH=/usr/local/bin/spotiflac-cli

# Download service: tidal, qobuz, amazon, deezer
SPF_DEFAULT_SERVICE=tidal

# Quality: lossless, hires, both
SPF_DEFAULT_QUALITY=lossless

# Max concurrent downloads
SPF_MAX_CONCURRENT=3

# Max time per download job
SPF_JOB_TIMEOUT=30m

# SQLite database path
SPF_DB_PATH=/data/queue.db

# Log level: debug, info, warn, error
SPF_LOG_LEVEL=info
