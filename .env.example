# Spotiflac-Lidarr Proxy configuration
# Copy this to .env and adjust for your setup

# Required: API key for Lidarr authentication
SPF_API_KEY=change-me-to-a-random-string

# HTTP listen port
SPF_PORT=8484

# Where completed FLAC downloads land (shared with Lidarr)
SPF_OUTPUT_DIR=/downloads

# Path to SpotiFLAC CLI binary
SPF_SPOTIFLAC_CLI_PATH=/usr/local/bin/spotiflac-cli

# Download service: tidal, qobuz, amazon, deezer
SPF_DEFAULT_SERVICE=tidal

# Quality: lossless, hires, both
SPF_DEFAULT_QUALITY=lossless

# Comma-separated fallback service chain tried once (no retries) if the
# primary service fails after all retries. Empty = disabled (default).
# Example: SPF_FALLBACK_SERVICES=tidal,qobuz,amazon,deezer
SPF_FALLBACK_SERVICES=

# Number of most-recent history entries to keep; older ones are pruned
# opportunistically on each new download add. 0 = unlimited.
SPF_HISTORY_RETENTION_COUNT=500

# Max concurrent downloads
SPF_MAX_CONCURRENT=3

# Max time per download job
SPF_JOB_TIMEOUT=30m

# SQLite database path
SPF_DB_PATH=/data/queue.db

# Log level: debug, info, warn, error
SPF_LOG_LEVEL=info

# --- Captcha Solving: Byparr / FlareSolverr (FSL) Proxy ---
# Auto-solves Cloudflare Turnstile during community verification.
# Point at byparr's FlareSolverr API (e.g. http://gluetun:8191 on the shared network).
# SPOTIFLAC_FSL_URL=http://byparr:8191
#
# This container's routable IP on the shared Docker network (used for
# the Turnstile callback that byparr's browser redirects to).
# Auto-detected from the default route interface if left empty,
# but it's more reliable to set it explicitly.
# SPOTIFLAC_ADDRESS=172.20.0.5

# --- Custom Tidal/Qobuz API (bypass community tier + Turnstile) ---
# Set these to self-hosted hifi-api instances or known public mirrors.
# When set, SpotiFLAC skips the community verification entirely.
# SPF_TIDAL_API_URL=https://your-hifi-api.example.com
# SPF_QOBUZ_API_URL=https://your-qobuz-api.example.com
#
# Fallback Tidal API URLs (comma-separated) — tried in order when primary
# TidalAPIURL is unset or fails. Known public mirrors (may need VPN):
# SPF_TIDAL_API_FALLBACK_URLS=https://api.monochrome.tf,https://wolf.qqdl.site,https://hifi.geeked.wtf
# Route through gluetun: set HTTP_PROXY=http://gluetun:8888 in docker-compose

# --- HTTP forward proxy (Go's http.Client auto-respects these) ---
# Route SpotiFLAC's outbound HTTP requests through a proxy (HTTP/SOCKS).
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080
